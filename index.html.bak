<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>墨滴</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --bg:#0a0a14;
  --bg2:#0e0e1a;
  --text:#e8e8f4;
  --text2:rgba(232,232,244,.6);
  --dim:#5a5a7a;
  --accent:#8b5cf6;
  --accent2:#6d9fff;
  --accent-glow:rgba(139,92,246,.15);
  --danger:#f43f6b;
  --success:#22c55e;
  --glass:rgba(14,14,26,.78);
  --glass-border:rgba(255,255,255,.06);
  --radius:14px;
  --radius-sm:10px;
  --shadow:0 8px 32px rgba(0,0,0,.55);
  --transition:.25s cubic-bezier(.4,0,.2,1);
}

body.light{
  --bg:#f5f4f9;
  --bg2:#eeedf3;
  --text:#1a1a2e;
  --text2:rgba(26,26,46,.55);
  --dim:#8888a0;
  --accent:#7c3aed;
  --accent2:#3b82f6;
  --accent-glow:rgba(124,58,237,.1);
  --danger:#e11d48;
  --success:#16a34a;
  --glass:rgba(245,244,249,.82);
  --glass-border:rgba(0,0,0,.06);
  --shadow:0 4px 20px rgba(0,0,0,.08);
}

body{
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','PingFang SC','Microsoft YaHei',sans-serif;
  background:var(--bg);color:var(--text);
  height:100vh;overflow:hidden;user-select:none;
  transition:background .4s ease,color .4s ease;
}

/* ═══════════════ Toolbar ═══════════════ */
.toolbar{
  position:fixed;top:0;left:0;right:0;height:40px;
  background:var(--glass);
  backdrop-filter:blur(28px) saturate(1.5);
  -webkit-backdrop-filter:blur(28px) saturate(1.5);
  border-bottom:1px solid var(--glass-border);
  display:flex;align-items:center;padding:0 12px;gap:4px;z-index:9999;
  transition:background var(--transition),border-color var(--transition),transform .3s ease,opacity .3s ease;
}
.toolbar-brand{
  font-size:14px;font-weight:800;letter-spacing:.5px;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  display:flex;align-items:center;gap:5px;margin-right:4px;flex-shrink:0;
}
.toolbar-brand svg{
  width:18px;height:18px;
  color:var(--accent);
  -webkit-text-fill-color:unset;
}
.badge{
  font-size:10px;font-weight:600;color:var(--accent);
  padding:2px 8px;border-radius:20px;
  background:var(--accent-glow);border:1px solid rgba(139,92,246,.12);
  margin-right:8px;white-space:nowrap;flex-shrink:0;
}

/* search */
.search-box{position:relative;margin-right:auto;flex-shrink:1}
.search-box input{
  width:160px;height:30px;border-radius:15px;
  border:1px solid var(--glass-border);
  background:rgba(255,255,255,.03);color:var(--text);
  font-size:12px;padding:0 12px 0 30px;outline:none;
  transition:all .3s ease;
}
.search-box input:focus{
  border-color:rgba(139,92,246,.3);width:220px;
  background:rgba(255,255,255,.05);
  box-shadow:0 0 0 3px rgba(139,92,246,.06);
}
.search-box input::placeholder{color:var(--dim);font-weight:400}
.search-box svg{
  position:absolute;left:10px;top:50%;transform:translateY(-50%);
  width:13px;height:13px;color:var(--dim);pointer-events:none;
}

/* buttons */
.btn{
  display:inline-flex;align-items:center;gap:4px;
  height:28px;padding:0 9px;border-radius:14px;
  border:1px solid var(--glass-border);
  background:rgba(255,255,255,.03);color:var(--text);
  font-size:11.5px;font-weight:500;cursor:pointer;
  transition:all var(--transition);white-space:nowrap;flex-shrink:0;
}
.btn:hover{
  background:var(--accent-glow);border-color:rgba(139,92,246,.25);
  color:#fff;transform:translateY(-1px);
  box-shadow:0 4px 14px rgba(139,92,246,.12);
}
.btn:active{transform:translateY(0);box-shadow:none}
.btn.active{
  background:var(--accent-glow);border-color:rgba(139,92,246,.3);
  color:var(--accent);
}
.btn.danger:hover{
  background:rgba(244,63,107,.12);border-color:rgba(244,63,107,.25);
  box-shadow:0 4px 14px rgba(244,63,107,.1);color:var(--danger);
}
.btn svg{width:13px;height:13px;flex-shrink:0}
.sep{width:1px;height:18px;background:var(--glass-border);margin:0 2px;flex-shrink:0}

/* ═══════════════ Canvas ═══════════════ */
.canvas{
  position:fixed;top:40px;left:0;right:0;bottom:0;overflow:auto;
  background-color:var(--bg);
  background-image:
    radial-gradient(ellipse 700px 500px at 15% 25%,rgba(139,92,246,.04) 0%,transparent 70%),
    radial-gradient(ellipse 600px 600px at 85% 75%,rgba(109,159,255,.03) 0%,transparent 70%),
    linear-gradient(rgba(255,255,255,.015) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,.015) 1px,transparent 1px);
  background-size:100% 100%,100% 100%,24px 24px,24px 24px;
  transition:background-color var(--transition);
}
body.light .canvas{
  background-image:
    radial-gradient(ellipse 700px 500px at 15% 25%,rgba(124,58,237,.03) 0%,transparent 70%),
    radial-gradient(ellipse 600px 600px at 85% 75%,rgba(59,130,246,.02) 0%,transparent 70%),
    linear-gradient(rgba(0,0,0,.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,0,0,.025) 1px,transparent 1px);
}

/* ═══════════════ Note Card ═══════════════ */
.note{
  position:absolute;width:280px;min-width:200px;min-height:180px;
  border-radius:var(--radius);
  border:1.5px solid var(--c-border);
  background:var(--c-bg);
  box-shadow:var(--shadow);display:flex;flex-direction:column;
  overflow:hidden;transition:box-shadow .3s,border-color .3s,transform .15s;
}
.note:hover{
  box-shadow:0 14px 48px rgba(0,0,0,.6);
  border-color:var(--c-accent);
}
.note.dragging{
  opacity:.93;z-index:10000!important;cursor:grabbing;
  box-shadow:0 24px 64px rgba(0,0,0,.7);transform:scale(1.03);
}
.note.collapsed .note-bd,.note.collapsed .note-meta,.note.collapsed .note-imgs{display:none}
.note.collapsed .rz{display:none}
.note.pinned{border-width:2px}
.note.pinned::after{
  content:'📌';position:absolute;top:-3px;left:8px;font-size:11px;z-index:2;
  filter:drop-shadow(0 1px 3px rgba(0,0,0,.6));
}
.note.hidden-search{display:none}

/* ── Checklist mode indicator ── */
.note.checklist-mode .note-bd{padding-top:4px}
.note.checklist-mode .note-hd::before{
  content:'☑';position:absolute;top:-1px;right:44px;font-size:10px;
  color:var(--c-accent);opacity:.5;
}

/* ── Color Themes ── */
.note[data-color="amber"]{
  --c-bg:linear-gradient(145deg,#2e2508,#382e0a);
  --c-border:rgba(255,200,50,.3);--c-dot:#ffc832;--c-accent:#ffc832;
  background:var(--c-bg);
}
.note[data-color="rose"]{
  --c-bg:linear-gradient(145deg,#2e0c18,#38101e);
  --c-border:rgba(255,100,130,.28);--c-dot:#ff6e8a;--c-accent:#ff6e8a;
  background:var(--c-bg);
}
.note[data-color="azure"]{
  --c-bg:linear-gradient(145deg,#0c1e2e,#102838);
  --c-border:rgba(80,180,255,.28);--c-dot:#50b4ff;--c-accent:#50b4ff;
  background:var(--c-bg);
}
.note[data-color="jade"]{
  --c-bg:linear-gradient(145deg,#0c2e16,#10381c);
  --c-border:rgba(80,220,120,.28);--c-dot:#50dc78;--c-accent:#50dc78;
  background:var(--c-bg);
}
.note[data-color="iris"]{
  --c-bg:linear-gradient(145deg,#1e0c2e,#281038);
  --c-border:rgba(170,100,255,.28);--c-dot:#aa64ff;--c-accent:#aa64ff;
  background:var(--c-bg);
}
.note[data-color="graphite"]{
  --c-bg:linear-gradient(145deg,#1e1e2e,#26263a);
  --c-border:rgba(140,140,180,.22);--c-dot:#9898b8;--c-accent:#9898b8;
  background:var(--c-bg);
}
.note[data-color="tangerine"]{
  --c-bg:linear-gradient(145deg,#2e1a08,#38200a);
  --c-border:rgba(255,150,50,.3);--c-dot:#ff9632;--c-accent:#ff9632;
  background:var(--c-bg);
}
.note[data-color="teal"]{
  --c-bg:linear-gradient(145deg,#0c2a2e,#103438);
  --c-border:rgba(50,210,220,.28);--c-dot:#32d2dc;--c-accent:#32d2dc;
  background:var(--c-bg);
}

/* ── Light Mode Note Colors ── */
body.light .note[data-color="amber"]{
  --c-bg:linear-gradient(145deg,#fff8e1,#fff3c4);
  --c-border:rgba(245,180,20,.3);--c-dot:#f5b414;--c-accent:#d4940a;
  background:var(--c-bg);
}
body.light .note[data-color="rose"]{
  --c-bg:linear-gradient(145deg,#fff0f3,#ffe4e8);
  --c-border:rgba(244,63,94,.2);--c-dot:#f43f5e;--c-accent:#dc2626;
  background:var(--c-bg);
}
body.light .note[data-color="azure"]{
  --c-bg:linear-gradient(145deg,#eff6ff,#dbeafe);
  --c-border:rgba(59,130,246,.2);--c-dot:#3b82f6;--c-accent:#2563eb;
  background:var(--c-bg);
}
body.light .note[data-color="jade"]{
  --c-bg:linear-gradient(145deg,#f0fdf4,#dcfce7);
  --c-border:rgba(34,197,94,.2);--c-dot:#22c55e;--c-accent:#16a34a;
  background:var(--c-bg);
}
body.light .note[data-color="iris"]{
  --c-bg:linear-gradient(145deg,#f5f3ff,#ede9fe);
  --c-border:rgba(139,92,246,.2);--c-dot:#8b5cf6;--c-accent:#7c3aed;
  background:var(--c-bg);
}
body.light .note[data-color="graphite"]{
  --c-bg:linear-gradient(145deg,#f8fafc,#f1f5f9);
  --c-border:rgba(148,163,184,.25);--c-dot:#94a3b8;--c-accent:#64748b;
  background:var(--c-bg);
}
body.light .note[data-color="tangerine"]{
  --c-bg:linear-gradient(145deg,#fff7ed,#ffedd5);
  --c-border:rgba(249,115,22,.2);--c-dot:#f97316;--c-accent:#ea580c;
  background:var(--c-bg);
}
body.light .note[data-color="teal"]{
  --c-bg:linear-gradient(145deg,#f0fdfa,#ccfbf1);
  --c-border:rgba(20,184,166,.2);--c-dot:#14b8a6;--c-accent:#0d9488;
  background:var(--c-bg);
}

/* light mode overrides */
body.light .note-title{color:#1a1a2e}
body.light .note-bd{color:rgba(0,0,0,.78)}
body.light .note-bd:empty::before{color:rgba(0,0,0,.18)}
body.light .note-bd b,.note-bd strong{color:#000}
body.light .note-meta{color:rgba(0,0,0,.22)}
body.light .rz::after{border-color:rgba(0,0,0,.12)}
body.light .empty svg{color:var(--accent);opacity:.15}
body.light .empty p{color:rgba(0,0,0,.22)}
body.light .empty .hint{color:rgba(0,0,0,.13)}
body.light .nbtn{color:#aaa}
body.light .nbtn:hover{color:#333;background:rgba(0,0,0,.05)}
body.light .nbtn.del:hover{color:var(--danger);background:rgba(225,29,72,.06)}
body.light .note:hover{box-shadow:0 10px 36px rgba(0,0,0,.1);border-color:var(--c-accent)}
body.light .note.dragging{box-shadow:0 18px 52px rgba(0,0,0,.14)}
body.light .cp-popup{background:rgba(255,255,255,.96);border-color:rgba(0,0,0,.07);box-shadow:0 10px 32px rgba(0,0,0,.1)}
body.light .ctx{background:rgba(255,255,255,.96);border-color:rgba(0,0,0,.05);box-shadow:0 10px 32px rgba(0,0,0,.1)}
body.light .ctx-item{color:#333}
body.light .ctx-item:hover{background:rgba(0,0,0,.04)}
body.light .ctx-sep{background:rgba(0,0,0,.05)}
body.light .font-popup{background:rgba(255,255,255,.96);border-color:rgba(0,0,0,.07);box-shadow:0 10px 32px rgba(0,0,0,.1)}
body.light .font-popup .row span{color:#555}
body.light .check-item.done .check-text{color:rgba(0,0,0,.28)}

/* header */
.note-hd{
  display:flex;align-items:center;padding:10px 10px;cursor:grab;gap:6px;flex-shrink:0;
  position:relative;
}
.note.dragging .note-hd{cursor:grabbing}
.note-title{
  flex:1;font-size:14px;font-weight:700;color:#f4f4ff;
  background:none;border:none;outline:none;cursor:text;user-select:text;
  min-width:0;letter-spacing:.3px;
}
.note-title::placeholder{color:rgba(255,255,255,.18);font-weight:500}
.note-meta{
  font-size:10px;color:rgba(255,255,255,.16);padding:0 12px 8px;flex-shrink:0;
  font-weight:500;letter-spacing:.4px;
}
.note-btns{display:flex;gap:1px;opacity:0;transition:opacity .2s}
.note:hover .note-btns{opacity:1}
.nbtn{
  width:26px;height:26px;border:none;background:transparent;color:var(--dim);
  cursor:pointer;border-radius:8px;display:flex;align-items:center;justify-content:center;
  transition:all .18s;
}
.nbtn:hover{background:rgba(255,255,255,.08);color:var(--text)}
.nbtn.del:hover{color:var(--danger);background:rgba(244,63,107,.08)}
.nbtn.active-btn{color:var(--c-accent)!important;opacity:1}
.nbtn svg{width:14px;height:14px}

/* color picker */
.cp-popup{
  position:absolute;top:44px;right:10px;
  background:rgba(20,20,40,.96);backdrop-filter:blur(16px);
  border:1px solid rgba(255,255,255,.07);border-radius:var(--radius-sm);
  padding:10px;display:none;gap:7px;flex-wrap:wrap;width:120px;
  box-shadow:0 14px 40px rgba(0,0,0,.6);z-index:100;
}
.cp-popup.show{display:flex}
.cdot{
  width:24px;height:24px;border-radius:7px;border:2px solid transparent;
  cursor:pointer;transition:all .18s;box-shadow:inset 0 0 0 1px rgba(0,0,0,.12);
}
.cdot:hover{transform:scale(1.2)}
.cdot.on{border-color:#fff;transform:scale(1.1)}
.cdot[data-c="amber"]{background:#ffc832}
.cdot[data-c="rose"]{background:#ff6e8a}
.cdot[data-c="azure"]{background:#50b4ff}
.cdot[data-c="jade"]{background:#50dc78}
.cdot[data-c="iris"]{background:#aa64ff}
.cdot[data-c="graphite"]{background:#9898b8}
.cdot[data-c="tangerine"]{background:#ff9632}
.cdot[data-c="teal"]{background:#32d2dc}

/* font size popup */
.font-popup{
  position:absolute;top:44px;right:40px;
  background:rgba(20,20,40,.96);backdrop-filter:blur(16px);
  border:1px solid rgba(255,255,255,.07);border-radius:var(--radius-sm);
  padding:10px 14px;display:none;flex-direction:column;gap:6px;min-width:140px;
  box-shadow:0 14px 40px rgba(0,0,0,.6);z-index:100;
}
.font-popup.show{display:flex}
.font-popup .row{
  display:flex;align-items:center;justify-content:space-between;gap:8px;
  font-size:12px;color:rgba(255,255,255,.6);
}
.font-popup .fs-btn{
  width:28px;height:28px;border:1px solid rgba(255,255,255,.08);border-radius:8px;
  background:rgba(255,255,255,.04);color:var(--text);cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:14px;
  transition:all .15s;
}
.font-popup .fs-btn:hover{background:rgba(139,92,246,.2);border-color:rgba(139,92,246,.3)}
.font-popup .fs-val{font-weight:600;min-width:40px;text-align:center;font-size:13px;color:var(--accent)}

/* content */
.note-bd{
  flex:1;padding:2px 14px 10px;font-size:15px;line-height:1.75;
  color:rgba(255,255,255,.82);outline:none;cursor:text;user-select:text;
  overflow-y:auto;white-space:pre-wrap;word-break:break-word;
  min-height:60px;
  transition:font-size .15s ease;
}
.note-bd:empty::before{content:'写点什么…';color:rgba(255,255,255,.15)}
.note-bd b,.note-bd strong{color:#fff}

/* images in note */
.note-bd img{
  max-width:100%;border-radius:8px;margin:6px 0;
  display:block;box-shadow:0 2px 12px rgba(0,0,0,.3);
  cursor:pointer;transition:box-shadow .2s;
}
.note-bd img:hover{box-shadow:0 4px 20px rgba(0,0,0,.5)}

/* ── Checklist ── */
.check-item{
  display:flex;align-items:flex-start;gap:8px;padding:3px 0;
  line-height:1.65;transition:opacity .2s;
}
.check-item.done{opacity:.45}
.check-item.done .check-text{text-decoration:line-through;color:rgba(255,255,255,.28)}
body.light .check-item.done .check-text{color:rgba(0,0,0,.25)}

.check-box{
  width:18px;height:18px;min-width:18px;border-radius:5px;margin-top:3px;
  border:2px solid var(--c-accent);cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;background:transparent;
}
.check-box:hover{background:rgba(255,255,255,.06)}
body.light .check-box:hover{background:rgba(0,0,0,.04)}
.check-item.done .check-box{
  background:var(--c-accent);border-color:var(--c-accent);
}
.check-box svg{
  width:12px;height:12px;stroke:#fff;stroke-width:3;fill:none;
  opacity:0;transform:scale(.5);transition:all .2s;
}
.check-item.done .check-box svg{opacity:1;transform:scale(1)}

.check-text{
  flex:1;outline:none;min-width:20px;color:rgba(255,255,255,.82);
}
body.light .check-text{color:rgba(0,0,0,.78)}

/* resize */
.rz{
  position:absolute;bottom:0;right:0;width:20px;height:20px;
  cursor:nwse-resize;opacity:0;transition:opacity .18s;
}
.note:hover .rz{opacity:.25}
.rz::after{
  content:'';position:absolute;bottom:6px;right:6px;
  width:7px;height:7px;
  border-right:1.5px solid rgba(255,255,255,.2);border-bottom:1.5px solid rgba(255,255,255,.2);
}

/* ═══════════════ Empty ═══════════════ */
.empty{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  text-align:center;pointer-events:none;
}
.empty svg{width:72px;height:72px;opacity:.1;margin-bottom:16px;color:var(--accent)}
.empty p{font-size:18px;color:rgba(255,255,255,.18);font-weight:600}
.empty .hint{font-size:13px;margin-top:10px;color:rgba(255,255,255,.1);font-weight:400}

/* ═══════════════ Context Menu ═══════════════ */
.ctx{
  position:fixed;
  background:rgba(20,20,42,.94);backdrop-filter:blur(24px);
  border:1px solid rgba(255,255,255,.06);border-radius:var(--radius-sm);
  padding:5px;min-width:180px;
  box-shadow:0 14px 40px rgba(0,0,0,.55);z-index:99999;display:none;
}
.ctx.show{display:block}
.ctx-item{
  display:flex;align-items:center;gap:9px;
  padding:8px 12px;border-radius:8px;font-size:13px;font-weight:500;
  color:rgba(255,255,255,.72);cursor:pointer;transition:all .12s;
}
.ctx-item:hover{background:rgba(255,255,255,.06);color:#fff}
.ctx-item svg{width:14px;height:14px;color:var(--dim);flex-shrink:0}
.ctx-item.danger{color:var(--danger)}
.ctx-item.danger svg{color:var(--danger)}
.ctx-item.danger:hover{background:rgba(244,63,107,.08)}
.ctx-sep{height:1px;background:rgba(255,255,255,.05);margin:4px 8px}

/* ═══════════════ Animations ═══════════════ */
@keyframes popIn{from{opacity:0;transform:scale(.88) translateY(12px)}to{opacity:1;transform:scale(1) translateY(0)}}
.note.entering{animation:popIn .28s cubic-bezier(.22,1,.36,1)}
@keyframes popOut{from{opacity:1;transform:scale(1)}to{opacity:0;transform:scale(.8) translateY(10px)}}
.note.removing{animation:popOut .2s ease-in forwards;pointer-events:none}

/* ═══════════════ Modal Overlay ═══════════════ */
.overlay{
  position:fixed;top:0;left:0;right:0;bottom:0;
  background:rgba(0,0,0,.45);backdrop-filter:blur(8px);
  z-index:999999;display:none;align-items:center;justify-content:center;
}
.overlay.show{display:flex}
.panel{
  background:rgba(16,16,36,.96);backdrop-filter:blur(24px);
  border:1px solid rgba(255,255,255,.07);border-radius:18px;
  padding:28px 34px;min-width:380px;max-width:440px;
  box-shadow:0 24px 64px rgba(0,0,0,.5);
}
.panel h3{
  font-size:17px;font-weight:700;color:var(--accent);margin-bottom:20px;
  display:flex;align-items:center;gap:9px;
}
.panel .row{
  display:flex;justify-content:space-between;align-items:center;
  padding:7px 0;font-size:13px;
}
.panel .row span{color:rgba(255,255,255,.55)}
.panel .key{
  display:inline-block;padding:2px 8px;border-radius:6px;
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08);
  font-family:'SF Mono',Monaco,Consolas,monospace;font-size:11.5px;
  color:rgba(255,255,255,.75);min-width:28px;text-align:center;
}
body.light .panel{
  background:rgba(255,255,255,.97);border-color:rgba(0,0,0,.05);
  box-shadow:0 24px 64px rgba(0,0,0,.12);
}
body.light .panel h3{color:var(--accent)}
body.light .panel .row span{color:#555}
body.light .panel .key{
  background:rgba(0,0,0,.04);border-color:rgba(0,0,0,.06);color:#333;
}

/* scrollbar */
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,.04);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:rgba(255,255,255,.08)}
body.light ::-webkit-scrollbar-thumb{background:rgba(0,0,0,.08)}
body.light ::-webkit-scrollbar-thumb:hover{background:rgba(0,0,0,.12)}

/* undo/redo toast */
.toast{
  position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);
  background:rgba(20,20,40,.92);backdrop-filter:blur(16px);
  border:1px solid rgba(255,255,255,.08);border-radius:12px;
  padding:8px 18px;font-size:12.5px;color:rgba(255,255,255,.7);
  box-shadow:0 8px 28px rgba(0,0,0,.4);z-index:999999;
  opacity:0;transition:all .3s ease;pointer-events:none;
}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
body.light .toast{background:rgba(255,255,255,.94);color:#333;border-color:rgba(0,0,0,.06)}

/* ═══════════════ Warm Message ═══════════════ */
.warm-msg{
  position:fixed;bottom:24px;right:24px;
  display:flex;align-items:center;gap:10px;
  padding:12px 18px;border-radius:16px;
  background:rgba(20,20,42,.72);
  backdrop-filter:blur(20px) saturate(1.4);
  -webkit-backdrop-filter:blur(20px) saturate(1.4);
  border:1px solid rgba(255,255,255,.06);
  box-shadow:0 8px 32px rgba(0,0,0,.3);
  font-size:13px;font-weight:500;
  color:rgba(255,255,255,.65);
  z-index:9998;cursor:pointer;
  transition:all .4s cubic-bezier(.4,0,.2,1);
  animation:warmFadeIn .5s ease;
  pointer-events:auto;
  max-width:320px;
}
.warm-msg:hover{
  background:rgba(20,20,42,.85);
  border-color:rgba(255,255,255,.1);
  color:rgba(255,255,255,.85);
}
.warm-msg .warm-emoji{
  font-size:20px;flex-shrink:0;
  animation:gentlePulse 3s ease-in-out infinite;
}
.warm-msg .warm-text{
  line-height:1.5;white-space:nowrap;
}
body.light .warm-msg{
  background:rgba(255,255,255,.82);
  border-color:rgba(0,0,0,.05);
  box-shadow:0 4px 20px rgba(0,0,0,.06);
  color:rgba(0,0,0,.5);
}
body.light .warm-msg:hover{
  background:rgba(255,255,255,.94);
  border-color:rgba(0,0,0,.08);
  color:rgba(0,0,0,.7);
}
@keyframes warmFadeIn{
  from{opacity:0;transform:translateY(12px) scale(.95)}
  to{opacity:1;transform:translateY(0) scale(1)}
}
@keyframes gentlePulse{
  0%,100%{transform:scale(1)}
  50%{transform:scale(1.08)}
}
.warm-msg.warm-fade-out{
  opacity:0;transform:translateY(8px) scale(.96);
}
.warm-msg.warm-fade-in{
  animation:warmFadeIn .45s ease forwards;
}
</style>
</head>
<body>

<!-- Toolbar -->
<div class="toolbar">
  <div class="toolbar-brand">
    <svg viewBox="0 0 24 24" fill="none">
      <rect x="3" y="3" width="14" height="18" rx="3" fill="currentColor" opacity="0.9"/>
      <rect x="7" y="1" width="14" height="18" rx="3" fill="currentColor" opacity="0.5"/>
      <path d="M17 1 L21 1 L21 5 Z" fill="currentColor" opacity="0.25"/>
      <line x1="7" y1="8" x2="15" y2="8" stroke="white" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
      <line x1="7" y1="11" x2="13" y2="11" stroke="white" stroke-width="1.2" stroke-linecap="round" opacity="0.4"/>
      <circle cx="15" cy="17" r="2.5" fill="#f9a8d4" opacity="0.85"/>
    </svg>
  </div>
  <span class="badge" id="cnt">0 张</span>
  <div class="search-box">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input id="searchInput" placeholder="搜索便笺…" spellcheck="false"/>
  </div>
  <button class="btn" id="btnUndo" title="撤销 Ctrl+Z">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
  </button>
  <button class="btn" id="btnRedo" title="重做 Ctrl+Y">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
  </button>
  <div class="sep"></div>
  <button class="btn" id="btnNew" title="新建 Ctrl+N">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
  </button>
  <button class="btn" id="btnArrange" title="自动排列">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
  </button>
  <button class="btn" id="btnTheme" title="切换主题">
    <svg id="themeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>
  <button class="btn" id="btnHelp" title="快捷键 (?)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
  </button>
  <button class="btn" id="btnExport" title="导出 JSON">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
  </button>
  <div class="sep"></div>
  <button class="btn danger" id="btnClear" title="清空">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
  </button>
</div>

<!-- Canvas -->
<div class="canvas" id="canvas">
  <div class="empty" id="empty">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15.5 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5L15.5 3Z"/><polyline points="14 3 14 8 21 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>
    <p>开始记录吧</p>
    <p class="hint">按 Ctrl+N 或双击空白区域</p>
  </div>
</div>

<!-- Context Menu -->
<div class="ctx" id="ctxMenu">
  <div class="ctx-item" data-act="pin"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 17v5"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg>置顶</div>
  <div class="ctx-item" data-act="collapse"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/></svg>折叠 / 展开</div>
  <div class="ctx-item" data-act="checklist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="6" height="6" rx="1"/><path d="M5 8l1.5 1.5L9 6"/><line x1="13" y1="8" x2="21" y2="8"/><rect x="3" y="13" width="6" height="6" rx="1"/><line x1="13" y1="16" x2="21" y2="16"/></svg>清单模式</div>
  <div class="ctx-item" data-act="duplicate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>复制便笺</div>
  <div class="ctx-sep"></div>
  <div class="ctx-item danger" data-act="delete"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>删除</div>
</div>

<!-- Shortcuts Overlay -->
<div class="overlay" id="shortcutsOverlay">
  <div class="panel">
    <h3>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="6" y1="8" x2="6.01" y2="8"/><line x1="10" y1="8" x2="10.01" y2="8"/><line x1="14" y1="8" x2="14.01" y2="8"/><line x1="18" y1="8" x2="18.01" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="6" y1="16" x2="18" y2="16"/></svg>
      快捷键
    </h3>
    <div class="row"><span>新建便笺</span><span><span class="key">Ctrl</span> + <span class="key">N</span></span></div>
    <div class="row"><span>双击空白区域</span><span>新建便笺</span></div>
    <div class="row"><span>加粗</span><span><span class="key">Ctrl</span> + <span class="key">B</span></span></div>
    <div class="row"><span>斜体</span><span><span class="key">Ctrl</span> + <span class="key">I</span></span></div>
    <div class="row"><span>下划线</span><span><span class="key">Ctrl</span> + <span class="key">U</span></span></div>
    <div class="row"><span>撤销</span><span><span class="key">Ctrl</span> + <span class="key">Z</span></span></div>
    <div class="row"><span>重做</span><span><span class="key">Ctrl</span> + <span class="key">Y</span></span></div>
    <div class="row"><span>粘贴图片</span><span><span class="key">Ctrl</span> + <span class="key">V</span></span></div>
    <div class="row"><span>右键便笺</span><span>更多操作</span></div>
    <div style="text-align:center;margin-top:18px;font-size:12px;color:rgba(255,255,255,.22)">按 Esc 关闭</div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<!-- Warm Message -->
<div class="warm-msg" id="warmMsg">
  <span class="warm-emoji" id="warmEmoji">☀️</span>
  <span class="warm-text" id="warmText">新的一天，加油！</span>
</div>

<script>
/* ══════════════════════════════════════════════════
   Config & State
   ══════════════════════════════════════════════════ */
const COLORS=['amber','rose','azure','jade','iris','graphite','tangerine','teal'];
const KEY='sticky-notes-v3';
const GRID=20;

let notes=[];
try{notes=JSON.parse(localStorage.getItem(KEY)||'[]')}catch(e){notes=[]}
// migrate from v2
if(!notes.length){
  try{notes=JSON.parse(localStorage.getItem('sticky-notes-v2')||'[]')}catch(e){}
}
const colorMap={yellow:'amber',coral:'rose',sky:'azure',mint:'jade',violet:'iris',slate:'graphite',peach:'tangerine',ocean:'teal',pink:'rose',blue:'azure',green:'jade',purple:'iris',gray:'graphite'};
notes=notes.map(n=>({...n,color:colorMap[n.color]||n.color,fontSize:n.fontSize||15,checklist:!!n.checklist,checks:n.checks||[]}));

let maxZ=notes.reduce((m,n)=>Math.max(m,n.z||10),10);
let ctxNoteId=null;

// Global undo stack (note-level changes)
const undoStack=[];
const redoStack=[];
const MAX_UNDO=50;

function snapshot(){
  undoStack.push(JSON.stringify(notes));
  if(undoStack.length>MAX_UNDO)undoStack.shift();
  redoStack.length=0;
}

function undo(){
  if(!undoStack.length){showToast('没有更多撤销');return}
  redoStack.push(JSON.stringify(notes));
  notes=JSON.parse(undoStack.pop());
  renderAll();localStorage.setItem(KEY,JSON.stringify(notes));
  showToast('已撤销');
}
function redo(){
  if(!redoStack.length){showToast('没有更多重做');return}
  undoStack.push(JSON.stringify(notes));
  notes=JSON.parse(redoStack.pop());
  renderAll();localStorage.setItem(KEY,JSON.stringify(notes));
  showToast('已重做');
}

/* ══════════════════════════════════════════════════
   DOM Refs
   ══════════════════════════════════════════════════ */
const canvas=document.getElementById('canvas');
const emptyEl=document.getElementById('empty');
const cntEl=document.getElementById('cnt');
const ctxMenu=document.getElementById('ctxMenu');
const searchInput=document.getElementById('searchInput');
const shortcutsOverlay=document.getElementById('shortcutsOverlay');
const toastEl=document.getElementById('toast');
const warmMsgEl=document.getElementById('warmMsg');
const warmEmojiEl=document.getElementById('warmEmoji');
const warmTextEl=document.getElementById('warmText');

/* ══════════════════════════════════════════════════
   Theme
   ══════════════════════════════════════════════════ */
let theme=localStorage.getItem('sticky-theme')||'dark';
function applyTheme(){
  document.body.classList.toggle('light',theme==='light');
  const icon=document.getElementById('themeIcon');
  icon.innerHTML=theme==='light'
    ?`<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>`
    :`<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>`;
}
applyTheme();
document.getElementById('btnTheme').addEventListener('click',()=>{
  theme=theme==='dark'?'light':'dark';
  localStorage.setItem('sticky-theme',theme);
  applyTheme();
});

/* ══════════════════════════════════════════════════
   Toast
   ══════════════════════════════════════════════════ */
let toastT;
function showToast(msg){
  toastEl.textContent=msg;toastEl.classList.add('show');
  clearTimeout(toastT);toastT=setTimeout(()=>toastEl.classList.remove('show'),1500);
}

/* ══════════════════════════════════════════════════
   Warm Messages ☀️
   ══════════════════════════════════════════════════ */
const WARM_MESSAGES=[
  // ☀️ 早安 6:00-9:00
  {h:6,m:0, msgs:[
    ['☀️','早安，新的一天开始了～'],
    ['🌅','早上好，今天也要元气满满哦！'],
    ['☕','早～先来杯咖啡提提神吧'],
    ['🌤️','清晨的阳光，属于每一个努力的你'],
    ['✨','新的一天，新的可能，加油！'],
    ['🌻','今天的你比昨天更厉害了'],
    ['🎵','早起的鸟儿有虫吃，早起的你有代码写'],
    ['💪','起床就是胜利，继续加油！'],
    ['📖','新的一页，由你书写'],
    ['🌈','又是充满希望的一天，冲！'],
  ]},
  // 💪 上午工作 9:00-11:30
  {h:9,m:0, msgs:[
    ['💪','上午好，专注工作吧～'],
    ['🎯','保持专注，你很棒！'],
    ['📝','一件一件来，不着急'],
    ['🔥','效率拉满，冲冲冲！'],
    ['🧠','思路清晰的时候最适合深度工作'],
    ['⚡','状态正佳，乘胜追击！'],
    ['🏗️','一个函数一个函数地搭建，大楼就起来了'],
    ['🧘','心无旁骛，沉浸在代码的世界里'],
    ['📈','每个小进步都是大成就的积累'],
    ['💎','耐心打磨，今天也能产出精品'],
  ]},
  // 🍱 午饭 11:30-13:30
  {h:11,m:30, msgs:[
    ['🍱','该吃午饭啦，别忘了吃饭～'],
    ['🍜','辛苦了一上午，去吃点好的吧！'],
    ['🥗','好好吃饭才有力气继续呀'],
    ['🍚','午饭时间到！记得多吃蔬菜哦'],
    ['🥢','再忙也要吃饭，身体最重要'],
    ['🥘','代码先放一放，犒劳一下肚子'],
    ['😋','想好吃什么了吗？别又点外卖随便对付'],
    ['🍲','热乎乎的饭菜在等你呢'],
    ['🧃','饭后来杯酸奶，助消化又开心'],
    ['🍕','午餐是一天中最值得期待的时刻之一'],
  ]},
  // 😴 午休 13:30-14:00
  {h:13,m:30, msgs:[
    ['😴','午休时间，眯一会儿吧～'],
    ['💤','小憩一下，下午更有精神'],
    ['🌙','闭眼休息 15 分钟，充电中…'],
    ['🧸','休息是为了走更远的路'],
    ['☁️','趴在桌上眯一会儿也行呀'],
    ['🛋️','沙发、工位、随便哪里，躺平五分钟'],
    ['🫧','放空大脑，让思绪飘一会儿'],
    ['⏰','定个 13:50 的闹钟，安心眯一下'],
    ['🌊','深呼吸，吸～呼～放松'],
    ['🧘‍♂️','闭目养神，也是一种高效'],
  ]},
  // 🌟 下午工作 14:00-17:30
  {h:14,m:0, msgs:[
    ['🌟','下午好，继续加油！'],
    ['⚡','睡醒了就满血复活啦～'],
    ['🚀','下半场开始，冲！'],
    ['💪','距离下班还有一会儿，稳住！'],
    ['🎵','下午适合听点音乐写代码'],
    ['🧊','泡杯冰美式，打起精神来'],
    ['🐛','Bug 不会自己修好，动手吧！'],
    ['🎯','下午冲刺，目标清晰'],
    ['🔄','休息好了就满状态了，开始干活！'],
    ['📂','整理一下手头的活，按优先级推进'],
  ]},
  // 🍽️ 晚饭 17:30-19:00
  {h:17,m:30, msgs:[
    ['🍽️','晚饭时间，辛苦一天了～'],
    ['🍜','下班啦！去吃顿好的犒劳自己'],
    ['🌆','傍晚了，该休息一下了'],
    ['🎉','今天的任务完成了吗？先吃饭！'],
    ['🌙','日落了，好好享受晚餐吧'],
    ['🏃','关电脑，走人，吃饭去！'],
    ['🍻','辛苦了，今晚对自己好一点'],
    ['🌇','看看窗外的晚霞，别一直盯着屏幕'],
    ['🥡','今天想吃点什么？火锅？烧烤？'],
    ['🧆','工作是做不完的，但晚饭是会凉的'],
  ]},
  // 🌙 晚间 19:00-22:00
  {h:19,m:0, msgs:[
    ['🌙','晚上好，放松一下吧～'],
    ['📚','晚上适合学点新东西'],
    ['🎬','追个剧？看个电影？'],
    ['🫖','泡杯茶，享受夜晚的宁静'],
    ['✨','忙碌了一天，这会儿属于自己了'],
    ['🎮','打两把游戏放松一下？'],
    ['🎵','戴上耳机，听一首喜欢的歌'],
    ['📱','给家人朋友发条消息吧'],
    ['🧘','做几分钟拉伸，活动活动筋骨'],
    ['📖','读几页书，比刷手机有意思多了'],
  ]},
  // 🌃 夜深了 22:00-24:00
  {h:22,m:0, msgs:[
    ['🌃','夜深了，早点休息哦～'],
    ['🛌','明天还有事呢，该睡啦'],
    ['🌠','放下屏幕，让眼睛休息一下'],
    ['🧸','晚安，好梦～'],
    ['💤','熬夜伤身，早点睡吧'],
    ['🌙','月亮都出来了，你也该休息了'],
    ['🫶','今天辛苦了，给自己一个拥抱'],
    ['🕯️','关灯，躺下，世界安静了'],
    ['😊','带着今天的小成就，安心入睡'],
    ['🌟','明天又是新的一天，晚安'],
  ]},
  // 🌑 深夜 0:00-6:00
  {h:0,m:0, msgs:[
    ['🌑','这么晚了还没睡呀？注意身体哦'],
    ['🦉','夜猫子模式开启…不过还是早点休息吧'],
    ['😶','凌晨了，身体比代码重要'],
    ['⏰','这么晚了，明天起得来吗？'],
    ['🫠','快去睡觉！明天再继续'],
    ['💤','别熬了，保存一下就去睡吧'],
    ['🫣','凌晨写出来的代码，明天可能要重构'],
    ['😪','大脑已经不转了，强撑没用的'],
    ['🌙','全世界都睡了，就你还在亮着屏幕'],
    ['🛏️','床在召唤你，别抗拒了'],
  ]},
];

function getWarmSlot(h,m){
  // Find the current time slot
  // Slots are ordered chronologically (6,9,11:30,13:30,14,17:30,19,22,0)
  const curMin=h*60+m;
  // Define slot boundaries in minutes from midnight
  const slots=[
    {start:0,   end:360,  idx:7},  // 0:00-6:00   深夜
    {start:360, end:540,  idx:0},  // 6:00-9:00   早安
    {start:540, end:690,  idx:1},  // 9:00-11:30  上午
    {start:690, end:810,  idx:2},  // 11:30-13:30 午饭
    {start:810, end:840,  idx:3},  // 13:30-14:00 午休
    {start:840, end:1050, idx:4},  // 14:00-17:30 下午
    {start:1050,end:1140, idx:5},  // 17:30-19:00 晚饭
    {start:1140,end:1320, idx:6},  // 19:00-22:00 晚间
    {start:1320,end:1440, idx:7},  // 22:00-24:00 夜深
  ];
  for(const s of slots){
    if(curMin>=s.start && curMin<s.end) return s.idx;
  }
  return 7; // fallback to 夜深
}

// Use date as seed so message is consistent within each hour, but changes each slot
function pickWarmMsg(){
  const now=new Date();
  const h=now.getHours(), m=now.getMinutes();
  const slotIdx=getWarmSlot(h,m);
  const slot=WARM_MESSAGES[slotIdx];
  // Use hour+date as seed for stable pick within slot
  const daySeed=now.getFullYear()*10000+(now.getMonth()+1)*100+now.getDate();
  const seed=(daySeed*7+slotIdx*13)%slot.msgs.length;
  return slot.msgs[seed];
}

let lastWarmSlot=-1;
function updateWarmMsg(){
  const now=new Date();
  const h=now.getHours(), m=now.getMinutes();
  const slotIdx=getWarmSlot(h,m);
  if(slotIdx===lastWarmSlot) return;
  lastWarmSlot=slotIdx;
  const [emoji,text]=pickWarmMsg();
  // Fade out, update, fade in
  warmMsgEl.classList.add('warm-fade-out');
  setTimeout(()=>{
    warmEmojiEl.textContent=emoji;
    warmTextEl.textContent=text;
    warmMsgEl.classList.remove('warm-fade-out');
    warmMsgEl.classList.add('warm-fade-in');
    setTimeout(()=>warmMsgEl.classList.remove('warm-fade-in'),500);
  },350);
}

// Init immediately
updateWarmMsg();
// Check every minute for slot changes
setInterval(updateWarmMsg,60000);

// Click to switch to a random message in current slot
let warmAnimating=false;
warmMsgEl.addEventListener('click',()=>{
  if(warmAnimating) return;
  warmAnimating=true;
  const now=new Date();
  const slotIdx=getWarmSlot(now.getHours(),now.getMinutes());
  const slot=WARM_MESSAGES[slotIdx];
  // Pick a different one from what's currently shown
  let pick;
  do{ pick=slot.msgs[Math.floor(Math.random()*slot.msgs.length)] }
  while(pick[1]===warmTextEl.textContent && slot.msgs.length>1);
  warmMsgEl.classList.add('warm-fade-out');
  setTimeout(()=>{
    warmEmojiEl.textContent=pick[0];
    warmTextEl.textContent=pick[1];
    warmMsgEl.classList.remove('warm-fade-out');
    warmMsgEl.classList.add('warm-fade-in');
    setTimeout(()=>{warmMsgEl.classList.remove('warm-fade-in');warmAnimating=false},450);
  },300);
});

/* ══════════════════════════════════════════════════
   Shortcuts Help
   ══════════════════════════════════════════════════ */
document.getElementById('btnHelp').addEventListener('click',()=>shortcutsOverlay.classList.add('show'));
shortcutsOverlay.addEventListener('click',e=>{if(e.target===shortcutsOverlay)shortcutsOverlay.classList.remove('show')});

/* ══════════════════════════════════════════════════
   Save & Count
   ══════════════════════════════════════════════════ */
let saveT;
function save(){clearTimeout(saveT);saveT=setTimeout(()=>localStorage.setItem(KEY,JSON.stringify(notes)),200)}
function updCnt(){
  const pinned=notes.filter(n=>n.pinned).length;
  cntEl.textContent=notes.length+' 张'+(pinned?` · ${pinned} 置顶`:'');
}

/* ══════════════════════════════════════════════════
   Helpers
   ══════════════════════════════════════════════════ */
function fmtTime(ts){
  if(!ts)return'';
  const d=new Date(ts),now=new Date();
  const pad=n=>String(n).padStart(2,'0');
  const time=pad(d.getHours())+':'+pad(d.getMinutes());
  if(d.toDateString()===now.toDateString())return'今天 '+time;
  const y=new Date(now);y.setDate(y.getDate()-1);
  if(d.toDateString()===y.toDateString())return'昨天 '+time;
  return`${d.getMonth()+1}/${d.getDate()} ${time}`;
}
function esc(s){const d=document.createElement('div');d.textContent=s;return d.innerHTML}
function stripHtml(html){const d=document.createElement('div');d.innerHTML=html;return d.textContent||''}
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2,7)}

/* ══════════════════════════════════════════════════
   Render All
   ══════════════════════════════════════════════════ */
function renderAll(){
  canvas.querySelectorAll('.note').forEach(e=>e.remove());
  const sorted=[...notes].sort((a,b)=>(b.pinned?1:0)-(a.pinned?1:0)||(b.z||0)-(a.z||0));
  sorted.forEach(n=>buildNote(n));
  emptyEl.style.display=notes.length?'none':'block';
  updCnt();
}

/* ══════════════════════════════════════════════════
   Build Note Element
   ══════════════════════════════════════════════════ */
function buildNote(n){
  const el=document.createElement('div');
  el.className='note entering'
    +(n.pinned?' pinned':'')
    +(n.collapsed?' collapsed':'')
    +(n.checklist?' checklist-mode':'');
  el.dataset.id=n.id;el.dataset.color=n.color||'amber';
  el.style.cssText=`left:${n.x}px;top:${n.y}px;width:${n.w||280}px;min-height:${n.h||180}px;z-index:${n.z||++maxZ}`;

  const pinIcon=n.pinned
    ?`<svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2"><path d="M12 17v5"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg>`
    :`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 17v5"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg>`;

  const foldIcon=n.collapsed
    ?`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"/></svg>`
    :`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>`;

  const checkIcon=n.checklist
    ?`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>`
    :`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>`;

  el.innerHTML=`
    <div class="note-hd">
      <input class="note-title" value="${esc(n.title||'')}" placeholder="标题" spellcheck="false"/>
      <div class="cp-popup" id="cp-${n.id}">
        ${COLORS.map(c=>`<div class="cdot${c===n.color?' on':''}" data-c="${c}"></div>`).join('')}
      </div>
      <div class="font-popup" id="fp-${n.id}">
        <div class="row"><span>字号</span><span class="fs-val" id="fsv-${n.id}">${n.fontSize||15}px</span></div>
        <div class="row">
          <button class="fs-btn" data-delta="-1">−</button>
          <button class="fs-btn" data-delta="0" style="font-size:11px;width:auto;padding:0 8px">重置</button>
          <button class="fs-btn" data-delta="1">+</button>
        </div>
      </div>
      <div class="note-btns">
        <button class="nbtn pin-btn${n.pinned?' active-btn':''}" title="${n.pinned?'取消置顶':'置顶'}">${pinIcon}</button>
        <button class="nbtn check-btn${n.checklist?' active-btn':''}" title="${n.checklist?'关闭清单':'清单模式'}">${checkIcon}</button>
        <button class="nbtn cp-btn" title="颜色"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3" fill="currentColor"/></svg></button>
        <button class="nbtn font-btn" title="字号"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9.5" y1="4" x2="9.5" y2="20"/><line x1="14.5" y1="4" x2="14.5" y2="20"/><line x1="7" y1="20" x2="17" y2="20"/></svg></button>
        <button class="nbtn fold-btn" title="${n.collapsed?'展开':'折叠'}">${foldIcon}</button>
        <button class="nbtn del" title="删除"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
    </div>
    <div class="note-bd" contenteditable="true" style="font-size:${n.fontSize||15}px"></div>
    <div class="note-meta">${fmtTime(n.created)}</div>
    <div class="rz"></div>`;

  canvas.appendChild(el);
  setTimeout(()=>el.classList.remove('entering'),250);

  /* refs */
  const hd=el.querySelector('.note-hd');
  const titleEl=el.querySelector('.note-title');
  const bd=el.querySelector('.note-bd');
  const cpPopup=el.querySelector('.cp-popup');
  const fontPopup=el.querySelector('.font-popup');
  const rz=el.querySelector('.rz');
  const pinBtn=el.querySelector('.pin-btn');
  const foldBtn=el.querySelector('.fold-btn');
  const checkBtn=el.querySelector('.check-btn');

  /* ── Populate content ── */
  if(n.checklist && n.checks && n.checks.length){
    renderChecklist(bd,n);
  } else {
    bd.innerHTML=n.content||'';
  }

  /* ── Focus / z ── */
  el.addEventListener('mousedown',()=>{if(!n.pinned){n.z=++maxZ;el.style.zIndex=n.z;save()}});

  /* ── Title ── */
  titleEl.addEventListener('input',()=>{snapshot();n.title=titleEl.value;save()});

  /* ── Content edit (normal mode) ── */
  bd.addEventListener('input',()=>{
    if(n.checklist)return; // checklist handles its own saves
    snapshot();
    n.content=bd.innerHTML;
    save();
  });

  /* ── Image paste ── */
  bd.addEventListener('paste',e=>{
    const items=(e.clipboardData||{}).items||[];
    let hasImage=false;
    for(const item of items){
      if(item.type.startsWith('image/')){
        e.preventDefault();
        hasImage=true;
        const blob=item.getAsFile();
        const reader=new FileReader();
        reader.onload=ev=>{
          snapshot();
          const img=document.createElement('img');
          img.src=ev.target.result;
          img.style.maxWidth='100%';
          img.style.borderRadius='8px';
          img.style.margin='6px 0';
          img.style.display='block';
          // insert at cursor
          const sel=window.getSelection();
          if(sel.rangeCount){
            const range=sel.getRangeAt(0);
            range.deleteContents();
            range.insertNode(img);
            // add line break after image
            const br=document.createElement('br');
            img.after(br);
            // move cursor after
            const r2=document.createRange();
            r2.setStartAfter(br);
            r2.collapse(true);
            sel.removeAllRanges();
            sel.addRange(r2);
          } else {
            bd.appendChild(img);
          }
          if(n.checklist){
            extractChecksFromDom(bd,n);
          } else {
            n.content=bd.innerHTML;
          }
          save();
        };
        reader.readAsDataURL(blob);
      }
    }
  });

  /* ── Keyboard ── */
  bd.addEventListener('keydown',e=>{
    if(e.ctrlKey||e.metaKey){
      if(e.key==='b'){e.preventDefault();document.execCommand('bold')}
      if(e.key==='i'){e.preventDefault();document.execCommand('italic')}
      if(e.key==='u'){e.preventDefault();document.execCommand('underline')}
    }
    // checklist: Enter to add new item, Backspace on empty to remove
    if(n.checklist){
      if(e.key==='Enter'&&!e.shiftKey){
        e.preventDefault();
        const sel=window.getSelection();
        if(!sel.rangeCount)return;
        const curItem=findCheckItem(sel.anchorNode);
        if(curItem){
          snapshot();
          const textEl=curItem.querySelector('.check-text');
          // split text at cursor
          const range=sel.getRangeAt(0);
          const beforeRange=document.createRange();
          beforeRange.setStart(textEl,0);
          beforeRange.setEnd(range.startContainer,range.startOffset);
          const afterRange=document.createRange();
          afterRange.setStart(range.endContainer,range.endOffset);
          afterRange.setEnd(textEl,textEl.childNodes.length);
          // create new item
          const newDiv=document.createElement('div');
          newDiv.className='check-item';
          newDiv.innerHTML=`<div class="check-box"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><div class="check-text" contenteditable="true"></div>`;
          curItem.after(newDiv);
          // focus new text
          const newtext=newDiv.querySelector('.check-text');
          newtext.focus();
          // save
          extractChecksFromDom(bd,n);
          save();
        }
      }
      if(e.key==='Backspace'){
        const sel=window.getSelection();
        if(!sel.rangeCount)return;
        const curItem=findCheckItem(sel.anchorNode);
        if(curItem){
          const textEl=curItem.querySelector('.check-text');
          if(textEl&&(textEl.textContent===''||textEl.textContent==='\n')){
            e.preventDefault();
            snapshot();
            const prev=curItem.previousElementSibling;
            curItem.remove();
            if(prev&&prev.classList.contains('check-item')){
              const pt=prev.querySelector('.check-text');
              pt.focus();
              // move cursor to end
              const range=document.createRange();
              range.selectNodeContents(pt);
              range.collapse(false);
              sel.removeAllRanges();
              sel.addRange(range);
            }
            extractChecksFromDom(bd,n);
            save();
          }
        }
      }
    }
  });

  /* ── Checklist toggle (click on checkbox) ── */
  bd.addEventListener('click',e=>{
    const box=e.target.closest('.check-box');
    if(box){
      e.preventDefault();
      const item=box.closest('.check-item');
      if(item){
        snapshot();
        item.classList.toggle('done');
        extractChecksFromDom(bd,n);
        save();
      }
    }
    // image preview (simple: click to toggle size)
    const img=e.target.closest('img');
    if(img){
      img.style.maxWidth=img.style.maxWidth==='100%'?'none':'100%';
    }
  });

  /* ── Checklist save on text input ── */
  bd.addEventListener('input',e=>{
    if(n.checklist){
      extractChecksFromDom(bd,n);
      save();
    }
  });

  /* ── Color picker ── */
  el.querySelector('.cp-btn').addEventListener('click',e=>{
    e.stopPropagation();
    closeAllPopups();
    cpPopup.classList.toggle('show');
  });
  cpPopup.querySelectorAll('.cdot').forEach(dot=>{
    dot.addEventListener('click',e=>{
      e.stopPropagation();snapshot();
      const c=dot.dataset.c;n.color=c;el.dataset.color=c;
      cpPopup.querySelectorAll('.cdot').forEach(d=>d.classList.remove('on'));
      dot.classList.add('on');cpPopup.classList.remove('show');save();
    });
  });

  /* ── Font size ── */
  el.querySelector('.font-btn').addEventListener('click',e=>{
    e.stopPropagation();closeAllPopups();
    fontPopup.classList.toggle('show');
  });
  fontPopup.querySelectorAll('.fs-btn').forEach(btn=>{
    btn.addEventListener('click',e=>{
      e.stopPropagation();snapshot();
      const delta=parseInt(btn.dataset.delta);
      if(delta===0){n.fontSize=15}
      else{n.fontSize=Math.max(10,Math.min(32,(n.fontSize||15)+delta))}
      bd.style.fontSize=n.fontSize+'px';
      document.getElementById('fsv-'+n.id).textContent=n.fontSize+'px';
      save();
    });
  });

  /* ── Pin ── */
  pinBtn.addEventListener('click',e=>{
    e.stopPropagation();snapshot();
    n.pinned=!n.pinned;
    el.classList.toggle('pinned',n.pinned);
    pinBtn.classList.toggle('active-btn',n.pinned);
    pinBtn.title=n.pinned?'取消置顶':'置顶';
    pinBtn.innerHTML=n.pinned
      ?`<svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2"><path d="M12 17v5"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg>`
      :`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 17v5"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg>`;
    if(n.pinned){n.z=++maxZ;el.style.zIndex=n.z}
    save();updCnt();
  });

  /* ── Checklist toggle ── */
  checkBtn.addEventListener('click',e=>{
    e.stopPropagation();snapshot();
    n.checklist=!n.checklist;
    el.classList.toggle('checklist-mode',n.checklist);
    checkBtn.classList.toggle('active-btn',n.checklist);
    checkBtn.title=n.checklist?'关闭清单':'清单模式';
    checkBtn.innerHTML=n.checklist
      ?`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>`
      :`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>`;

    if(n.checklist){
      // convert current content to checklist items
      const text=stripHtml(n.content||'').trim();
      const lines=text?text.split('\n').filter(l=>l.trim()):[''];
      n.checks=lines.map(l=>({text:l.trim(),done:false}));
      n.content=bd.innerHTML; // save old content
      renderChecklist(bd,n);
    } else {
      // convert checklist back to text
      extractChecksFromDom(bd,n);
      const text=n.checks.map(c=>c.text).join('\n');
      n.content=text;
      n.checks=[];
      bd.innerHTML=text;
    }
    save();
  });

  /* ── Fold ── */
  foldBtn.addEventListener('click',e=>{
    e.stopPropagation();snapshot();
    n.collapsed=!n.collapsed;
    el.classList.toggle('collapsed',n.collapsed);
    foldBtn.innerHTML=n.collapsed
      ?`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"/></svg>`
      :`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>`;
    foldBtn.title=n.collapsed?'展开':'折叠';
    save();
  });

  /* ── Delete ── */
  el.querySelector('.del').addEventListener('click',e=>{e.stopPropagation();deleteNote(n.id)});

  /* ── Context menu ── */
  el.addEventListener('contextmenu',e=>{
    e.preventDefault();e.stopPropagation();
    ctxNoteId=n.id;
    // update checklist label
    const clItem=ctxMenu.querySelector('[data-act="checklist"]');
    if(clItem){
      clItem.innerHTML=n.checklist
        ?`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>关闭清单模式`
        :`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="6" height="6" rx="1"/><path d="M5 8l1.5 1.5L9 6"/><line x1="13" y1="8" x2="21" y2="8"/><rect x="3" y="13" width="6" height="6" rx="1"/><line x1="13" y1="16" x2="21" y2="16"/></svg>清单模式`;
    }
    ctxMenu.style.left=Math.min(e.clientX,window.innerWidth-200)+'px';
    ctxMenu.style.top=Math.min(e.clientY,window.innerHeight-200)+'px';
    ctxMenu.classList.add('show');
  });

  /* ── Drag ── */
  let drag=false,ox,oy;
  hd.addEventListener('mousedown',e=>{
    if(e.target.closest('.nbtn,.cdot,.fs-btn,.cp-popup,.font-popup,.note-title'))return;
    drag=true;el.classList.add('dragging');
    const r=el.getBoundingClientRect();
    ox=e.clientX-r.left;oy=e.clientY-r.top;
    n.z=++maxZ;el.style.zIndex=n.z;e.preventDefault();
  });

  /* ── Resize ── */
  let rsz=false,rw,rh,rmx,rmy;
  rz.addEventListener('mousedown',e=>{
    rsz=true;rw=el.offsetWidth;rh=el.offsetHeight;
    rmx=e.clientX;rmy=e.clientY;e.preventDefault();e.stopPropagation();
  });

  const mv=e=>{
    if(drag){
      let x=e.clientX-ox,y=e.clientY-oy-56;
      x=Math.round(x/GRID)*GRID;y=Math.round(y/GRID)*GRID;
      const maxX=canvas.scrollWidth-60,maxY=canvas.scrollHeight-60;
      n.x=Math.max(-el.offsetWidth+60,Math.min(x,maxX));
      n.y=Math.max(-el.offsetHeight+60,Math.min(y,maxY));
      el.style.left=n.x+'px';el.style.top=n.y+'px';
    }
    if(rsz){
      let w=Math.max(200,rw+e.clientX-rmx);
      let h=Math.max(180,rh+e.clientY-rmy);
      w=Math.round(w/GRID)*GRID;h=Math.round(h/GRID)*GRID;
      n.w=w;n.h=h;el.style.width=w+'px';el.style.minHeight=h+'px';
    }
  };
  const up=()=>{
    if(drag){drag=false;el.classList.remove('dragging');save()}
    if(rsz){rsz=false;save()}
  };
  // store for cleanup
  el._mv=mv;el._up=up;
  document.addEventListener('mousemove',mv);
  document.addEventListener('mouseup',up);
}

/* ══════════════════════════════════════════════════
   Checklist Helpers
   ══════════════════════════════════════════════════ */
function renderChecklist(bd,n){
  bd.innerHTML='';
  (n.checks||[]).forEach(c=>{
    const div=document.createElement('div');
    div.className='check-item'+(c.done?' done':'');
    div.innerHTML=`<div class="check-box"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><div class="check-text" contenteditable="true">${esc(c.text)}</div>`;
    bd.appendChild(div);
  });
  // add empty item if last is not empty
  const checks=n.checks||[];
  if(!checks.length||checks[checks.length-1].text){
    const div=document.createElement('div');
    div.className='check-item';
    div.innerHTML=`<div class="check-box"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><div class="check-text" contenteditable="true"></div>`;
    bd.appendChild(div);
  }
}

function extractChecksFromDom(bd,n){
  const items=bd.querySelectorAll('.check-item');
  n.checks=[];
  items.forEach(item=>{
    const text=(item.querySelector('.check-text')||{}).textContent||'';
    const done=item.classList.contains('done');
    n.checks.push({text:text.trim(),done});
  });
  // remove trailing empty items except keep one
  while(n.checks.length>1&&!n.checks[n.checks.length-1].text&&!n.checks[n.checks.length-1].done){
    n.checks.pop();
  }
}

function findCheckItem(node){
  while(node&&!node.classList?.contains('check-item')){
    node=node.parentElement;
    if(!node||node.classList?.contains('note-bd'))return null;
  }
  return node;
}

/* ══════════════════════════════════════════════════
   CRUD
   ══════════════════════════════════════════════════ */
function deleteNote(id){
  snapshot();
  const el=canvas.querySelector(`[data-id="${id}"]`);
  if(el){
    el.classList.add('removing');
    setTimeout(()=>{
      // cleanup listeners
      if(el._mv)document.removeEventListener('mousemove',el._mv);
      if(el._up)document.removeEventListener('mouseup',el._up);
      notes=notes.filter(x=>x.id!==id);
      el.remove();emptyEl.style.display=notes.length?'none':'block';updCnt();save();
    },180);
  }
}

function duplicateNote(id){
  snapshot();
  const src=notes.find(n=>n.id===id);
  if(!src)return;
  const n={...src,id:uid(),x:src.x+30,y:src.y+30,z:++maxZ,created:Date.now(),pinned:false,checks:[...(src.checks||[]).map(c=>({...c}))]};
  notes.push(n);buildNote(n);emptyEl.style.display='none';updCnt();save();
}

function newNote(){
  snapshot();
  const id=uid();
  const x=Math.round((40+Math.random()*120+canvas.scrollLeft)/GRID)*GRID;
  const y=Math.round((20+Math.random()*60+canvas.scrollTop)/GRID)*GRID;
  const n={
    id,title:'',content:'',
    color:COLORS[Math.floor(Math.random()*COLORS.length)],
    x,y,w:280,h:200,z:++maxZ,created:Date.now(),pinned:false,collapsed:false,
    fontSize:15,checklist:false,checks:[],
  };
  notes.push(n);buildNote(n);
  emptyEl.style.display='none';updCnt();save();
  setTimeout(()=>{const e=canvas.querySelector(`[data-id="${id}"] .note-bd`);if(e)e.focus()},50);
}

/* ── Auto Arrange (Masonry) ── */
function arrange(){
  if(!notes.length)return;
  snapshot();
  const pad=16,gap=14;
  const cw=canvas.clientWidth-pad*2;
  const minColW=260;
  const cols=Math.max(1,Math.floor((cw+gap)/(minColW+gap)));
  const colW=(cw-(cols-1)*gap)/cols;
  const hiddenIds=new Set();
  canvas.querySelectorAll('.note.hidden-search').forEach(el=>hiddenIds.add(el.dataset.id));
  const sorted=[...notes].filter(n=>!hiddenIds.has(n.id)).sort((a,b)=>(b.pinned?1:0)-(a.pinned?1:0)||(a.created||0)-(b.created||0));
  // Track actual height of each column (masonry layout)
  const colHeights=new Array(cols).fill(pad);
  sorted.forEach(n=>{
    // Find shortest column
    let minCol=0;
    for(let c=1;c<cols;c++){if(colHeights[c]<colHeights[minCol])minCol=c}
    // Position note in shortest column
    n.x=pad+minCol*(colW+gap);
    n.y=colHeights[minCol];
    // Update column height
    const noteH=n.h||200;
    colHeights[minCol]+=noteH+gap;
    // Apply width
    n.w=Math.round(colW);
    // Animate
    const el=canvas.querySelector(`[data-id="${n.id}"]`);
    if(el){
      el.style.transition='left .35s ease,top .35s ease,width .35s ease';
      el.style.left=n.x+'px';el.style.top=n.y+'px';el.style.width=n.w+'px';
      setTimeout(()=>el.style.transition='',400);
    }
  });
  save();
}

/* ── Export ── */
function exportNotes(){
  const blob=new Blob([JSON.stringify(notes,null,2)],{type:'application/json'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download=`便笺_${new Date().toISOString().slice(0,10)}.json`;
  a.click();URL.revokeObjectURL(a.href);
}

/* ── Search ── */
searchInput.addEventListener('input',()=>{
  const q=searchInput.value.trim().toLowerCase();
  canvas.querySelectorAll('.note').forEach(el=>{
    const id=el.dataset.id;
    const n=notes.find(x=>x.id===id);
    if(!n){el.classList.add('hidden-search');return}
    let text=(n.title||'')+' '+(n.checklist?(n.checks||[]).map(c=>c.text).join(' '):stripHtml(n.content||''));
    el.classList.toggle('hidden-search',q&&!text.toLowerCase().includes(q));
  });
});

/* ── Clear ── */
document.getElementById('btnClear').addEventListener('click',()=>{
  if(!notes.length)return;
  if(!confirm('确定清空所有便笺？不可恢复。'))return;
  snapshot();notes=[];renderAll();save();
});

/* ══════════════════════════════════════════════════
   Context Menu Actions
   ══════════════════════════════════════════════════ */
ctxMenu.querySelectorAll('.ctx-item').forEach(item=>{
  item.addEventListener('click',()=>{
    if(!ctxNoteId)return;
    const act=item.dataset.act;
    if(act==='delete')deleteNote(ctxNoteId);
    if(act==='duplicate')duplicateNote(ctxNoteId);
    if(act==='pin'){
      const n=notes.find(x=>x.id===ctxNoteId);
      if(n){snapshot();n.pinned=!n.pinned;renderAll();save()}
    }
    if(act==='collapse'){
      const n=notes.find(x=>x.id===ctxNoteId);
      if(n){snapshot();n.collapsed=!n.collapsed;renderAll();save()}
    }
    if(act==='checklist'){
      const n=notes.find(x=>x.id===ctxNoteId);
      if(n){
        snapshot();n.checklist=!n.checklist;
        const el=canvas.querySelector(`[data-id="${ctxNoteId}"]`);
        if(el){
          el.classList.toggle('checklist-mode',n.checklist);
          const checkBtn=el.querySelector('.check-btn');
          if(checkBtn){
            checkBtn.classList.toggle('active-btn',n.checklist);
            checkBtn.title=n.checklist?'关闭清单':'清单模式';
            checkBtn.innerHTML=n.checklist
              ?`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>`
              :`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>`;
          }
          const bd=el.querySelector('.note-bd');
          if(n.checklist){
            const text=stripHtml(n.content||'').trim();
            const lines=text?text.split('\n').filter(l=>l.trim()):[''];
            n.checks=lines.map(l=>({text:l.trim(),done:false}));
            renderChecklist(bd,n);
          } else {
            extractChecksFromDom(bd,n);
            const text=n.checks.map(c=>c.text).join('\n');
            n.content=text;n.checks=[];bd.innerHTML=text;
          }
        }
        save();
      }
    }
    ctxMenu.classList.remove('show');ctxNoteId=null;
  });
});

/* ══════════════════════════════════════════════════
   Global Events
   ══════════════════════════════════════════════════ */
function closeAllPopups(){
  document.querySelectorAll('.cp-popup.show,.font-popup.show').forEach(p=>p.classList.remove('show'));
}
document.addEventListener('click',e=>{
  if(!e.target.closest('.ctx'))ctxMenu.classList.remove('show');
  if(!e.target.closest('.cp-popup,.cp-btn')&&!e.target.closest('.font-popup,.font-btn'))closeAllPopups();
});
document.addEventListener('contextmenu',e=>{if(!e.target.closest('.note'))ctxMenu.classList.remove('show')});
canvas.addEventListener('dblclick',e=>{if(!e.target.closest('.note'))newNote()});

/* ── Global Keyboard ── */
document.addEventListener('keydown',e=>{
  if((e.ctrlKey||e.metaKey)&&e.key==='n'){e.preventDefault();newNote()}
  if((e.ctrlKey||e.metaKey)&&e.key==='z'&&!e.target.closest('[contenteditable]')){e.preventDefault();undo()}
  if((e.ctrlKey||e.metaKey)&&(e.key==='y'||(e.shiftKey&&e.key==='Z'))&&!e.target.closest('[contenteditable]')){e.preventDefault();redo()}
  if(e.key==='Escape'){
    if(shortcutsOverlay.classList.contains('show')){shortcutsOverlay.classList.remove('show');return}
    if(searchInput.value){searchInput.value='';searchInput.dispatchEvent(new Event('input'));searchInput.blur();return}
    ctxMenu.classList.remove('show');closeAllPopups();
  }
  if((e.key==='?'||e.key==='？')&&!e.target.closest('[contenteditable],input')){
    e.preventDefault();shortcutsOverlay.classList.toggle('show');
  }
});

/* ── Toolbar Buttons ── */
document.getElementById('btnNew').addEventListener('click',newNote);
document.getElementById('btnArrange').addEventListener('click',arrange);
document.getElementById('btnExport').addEventListener('click',exportNotes);
document.getElementById('btnUndo').addEventListener('click',undo);
document.getElementById('btnRedo').addEventListener('click',redo);

/* ══════════════════════════════════════════════════
   Init
   ══════════════════════════════════════════════════ */
renderAll();

/* ── Electron IPC ── */
if(window.electronAPI){
  window.electronAPI.onShortcut(action=>{
    if(action==='new-note')newNote();
  });
}
</script>
</body>
</html>
